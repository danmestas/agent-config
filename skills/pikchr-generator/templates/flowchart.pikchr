# Flowchart template — top-down decision flow with stdlib macros.
# Compile with: compile.sh --with-stdlib --theme NAME

down
Start:    actor("Start")
arrow
Validate: lambda("Validate input")
arrow
Check:    decision("Valid?")
arrow "yes" rjust
Process:  lambda("Process")
arrow
Save:     db("Save to DB")
arrow
End:      actor("Done")

# "no" branch from Check
arrow from Check.e right then up to (Check.e + (1.5, 0)) "no" above
ErrBox:   note("Show error") at (Check.e + (1.8, 0))
arrow from ErrBox.n up then left to End.e
