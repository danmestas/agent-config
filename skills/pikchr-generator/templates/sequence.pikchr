# Sequence-ish template — actors with vertical lifelines + horizontal messages.
# Pikchr has no native sequence diagram; this is the idiomatic approximation.
# Compile with: compile.sh --with-stdlib --theme NAME

actorBox = 0.6
lifeline = 2.5

right
A: actor("Client") wid actorBox
move 1.5
B: actor("API")    wid actorBox
move 1.5
C: actor("DB")     wid actorBox

# Lifelines — sentinel "muted" so they fade into the theme palette
line dashed color 0x303132 from A.s down lifeline
line dashed color 0x303132 from B.s down lifeline
line dashed color 0x303132 from C.s down lifeline

# Messages
arrow from A.s + (0,-0.4) to B.s + (0,-0.4) "POST /login" above
arrow from B.s + (0,-0.9) to C.s + (0,-0.9) "SELECT user" above
arrow from C.s + (0,-1.4) to B.s + (0,-1.4) "row"        above dashed
arrow from B.s + (0,-1.9) to A.s + (0,-1.9) "200 OK"     above dashed
