# Swim lane template — three lanes with steps in each.
# Compile with: compile.sh --with-stdlib --theme NAME
# All colors come from the 7-token sentinel palette so themes apply.

laneH = 1.0
laneW = 5.0

# Lanes (line-colored borders, no fill — the theme background shows through)
LANE1: box wid laneW ht laneH thin color 0x101112
"Frontend" big ljust at LANE1.w + (0.1, 0)

LANE2: box wid laneW ht laneH thin color 0x101112 with .n at LANE1.s
"Backend"  big ljust at LANE2.w + (0.1, 0)

LANE3: box wid laneW ht laneH thin color 0x101112 with .n at LANE2.s
"Database" big ljust at LANE3.w + (0.1, 0)

# Frontend steps (accent fill, inverted text — primary actions)
S1: actor("Click")    at LANE1.w + (1.2, 0)
arrow right from S1.e
S2: actor("Validate")
arrow right
S3: actor("Submit")

# Cross-lane: frontend → backend
arrow from S3.s down to (S3.s.x, LANE2.s.y) "POST" rjust
B1: lambda("Process") at (S3.s.x, LANE2.c.y)

# Cross-lane: backend → database
arrow from B1.s down to (B1.s.x, LANE3.c.y) "INSERT" rjust
D1: db("Persist")     at (B1.s.x, LANE3.c.y)
