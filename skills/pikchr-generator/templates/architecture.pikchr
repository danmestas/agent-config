# System architecture template — component layout with stdlib macros.
# Compile with: compile.sh --with-stdlib --theme NAME
#
# Every fill/stroke uses sentinel colors (via stdlib macros), so themes apply
# uniformly. To add a new node type, prefer a stdlib macro; if you must inline
# colors, use only the 7 sentinels (#010203, #0a0b0c, #101112, #202122,
# #303132, #404142, #505152).

right
Web:  actor("Web App")
arrow
API:  actor("API Gateway")
arrow
Auth: lambda("Auth")

# Service tier sits below the gateway
Svc:  lambda("Service")  at API.s + (0, -1.2)
arrow from API.s down to Svc.n

# Persistence
arrow from Svc.s down
DB:   db("Postgres")

# Side: cache + queue (sentinel colors so the theme reaches them)
Cache: box "Redis" fit \
  fill 0x303132 color 0x0a0b0c thickness 1.5px rad 5px \
  at Svc.e + (1.5, 0)
arrow from Svc.e right to Cache.w "cache" above

Queue: queue("Jobs") at DB.e + (1.5, 0)
arrow from Svc.e + (0, -0.6) right then down to Queue.n
