/* GraphViz stdlib — injected into user graphs by `compile-dot.sh --with-stdlib`.
 *
 * CANNOT be prepended standalone: `graph[]`, `node[]`, and `edge[]` attribute
 * blocks are only syntactically valid INSIDE a `digraph { ... }` body.
 * compile-dot.sh splices this file's contents after the user's opening `{`.
 *
 * Uses the 7-token sentinel palette (see lib/themeize.sh):
 *   #010203 bg       #0a0b0c fg        #101112 line
 *   #202122 accent   #303132 muted     #404142 surface    #505152 border
 *
 * After compile-dot.sh pipes dot's SVG output through themeize.sh, these
 * sentinels are rewritten to var(--bg), var(--fg), etc.
 *
 * Role assignment for user diagrams:
 *   DB         (passive):  shape=cylinder          fillcolor="#404142"  (surface)
 *   CLOUD      (passive):  shape=ellipse           fillcolor="#404142"  (surface)
 *   ACTOR      (primary):  shape=box rounded       fillcolor="#202122"  (accent)
 *   QUEUE      (secondary):shape=parallelogram     fillcolor="#303132"  (muted)
 *   LAMBDA     (primary):  shape=box rounded       fillcolor="#202122"  (accent)
 *   DATASTORE  (passive):  shape=folder            fillcolor="#404142"  (surface)
 *   DECISION   (primary):  shape=diamond           fillcolor="#202122"  (accent)
 *   NOTE       (annot):    shape=note              fillcolor="#303132"  (muted, dashed)
 */

graph [
  bgcolor="transparent"
  fontname="sans-serif"
  fontcolor="#0a0b0c"
  color="#101112"
  pad=0.25
  rankdir=TB
]

node [
  shape=box
  style="rounded,filled"
  fillcolor="#404142"
  color="#505152"
  fontcolor="#0a0b0c"
  fontname="sans-serif"
  penwidth=1.5
  margin="0.15,0.08"
]

edge [
  color="#101112"
  fontcolor="#303132"
  fontname="sans-serif"
  arrowsize=0.8
  penwidth=1.0
]
